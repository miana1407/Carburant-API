# ──────────────────────────────────────────
# Serveur
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────
# Base de données PostgreSQL
# ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=carburant_db

# ──────────────────────────────────────────
# Authentification JWT
# ──────────────────────────────────────────
JWT_SECRET=une_cle_secrete_tres_longue_a_changer_en_prod
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────
# Import de données
# ──────────────────────────────────────────
# URL pour l'import des prix depuis gouv.fr
FUEL_PRICES_URL=https://donnees.roulez-eco.fr/opendata/jour

# ──────────────────────────────────────────
# Scheduler - Cron jobs
# ─────────────────────────────────────────
# Format cron (0 6 * * * = chaque jour à 6h)
CRON_SCHEDULE=0 6 * * *
